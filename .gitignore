# Yüklenen dosyalar ve storage (büyük, kişisel veriler)
/storage/backups/
/storage/exports/
/storage/logs/
/storage/images/

# Geçici ve debug dosyaları
/tmp/
/fix_db_translations.php
*.log

# Vendor / node_modules
/vendor/
/node_modules/

# OS dosyaları
.DS_Store
Thumbs.db
desktop.ini

# IDE dosyaları
.vscode/
.idea/
*.swp
*.swo

# Antigravity (AI assistant)
.antigravityignore
/.gemini/
